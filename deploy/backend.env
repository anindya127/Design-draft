# GCSS Backend — production environment
# Loaded by systemd via EnvironmentFile=/opt/gcss-backend/.env

PORT=8080
CORS_ORIGINS=https://v3.gcss.hk,https://gcss.hk,https://www.gcss.hk,http://localhost:3000
DB_PATH=/opt/gcss-backend/data/gcss.sqlite
DATA_FILE=/opt/gcss-backend/data/requests.jsonl
UPLOAD_DIR=/opt/gcss-backend/data/uploads

# Encryption secret for user PII (PBKDF2 key derivation + AES-256-GCM)
ENCRYPTION_SECRET=gcss-v3-prod-encryption-key-2026

# Disable demo reset codes in production
AUTH_RETURN_RESET_CODE=false
